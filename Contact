<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Contact</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 2em;
      background-color: #f9f9f9;
      color: #333;
    }

    h1 {
      text-align: center;
      margin-bottom: 1em;
    }

    .social-links {
      display: flex;
      justify-content: center;
      gap: 2em;
      margin-bottom: 2em;
    }

    .social-links a {
      text-decoration: none;
      color: #0077b5; /* Default to LinkedIn blue */
      font-size: 1.2em;
    }

    form {
      max-width: 600px;
      margin: 0 auto;
      background: white;
      padding: 2em;
      border-radius: 8px;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }

    input, textarea {
      width: 100%;
      padding: 0.75em;
      margin-top: 0.5em;
      margin-bottom: 1.5em;
      border: 1px solid #ccc;
      border-radius: 5px;
      font-size: 1em;
    }

    button {
      padding: 0.75em 2em;
      background-color: #333;
      color: white;
      border: none;
      border-radius: 5px;
      cursor: pointer;
    }

    button:hover {
      background-color: #555;
    }
  </style>
</head>
<body>

  <h1>Contact Me</h1>

  <div class="social-links">
    <a href="https://www.linkedin.com/in/joshua-odiase-0a5488240/" target="_blank">LinkedIn</a>
    <a href="https://www.instagram.com/joshodiase/" target="_blank">Instagram</a>
    <a href="mailto:0dysseyyinquiries@gmail.com">Email</a>
  </div>

  <form action="mailto:0dysseyyinquiries@gmail.com" method="POST" enctype="text/plain">
    <label for="name">Joshua Odiase</label>
    <input type="text" id="name" name="name" required />

    <label for="email">Your Email</label>
    <input type="email" id="email" name="email" required />

    <label for="message">Inquiry</label>
    <textarea id="message" name="message" rows="6" required></textarea>

    <button type="submit">Send</button>
  </form>

</body>
</html>
